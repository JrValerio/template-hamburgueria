# Normalize all text files to LF in the repository
* text=auto eol=lf

# Explicit overrides
*.md   text eol=lf
*.json text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.css  text eol=lf
*.html text eol=lf

# Binary — never mangle
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.woff binary
*.woff2 binary
