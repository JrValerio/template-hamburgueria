# Base URL for the product catalog API.
# Production: point to your json-server on Render (no trailing slash).
#   Example: VITE_API_BASE_URL=https://template-hamburgueria-api.onrender.com
# Development: leave unset to use the default fallback, or set to localhost.
#   Example: VITE_API_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=https://hamburgueria-kenzie-json-serve.herokuapp.com/

# Set to "true" to force the local seed catalog regardless of API availability.
# Useful for development without network access or to smoke-test the offline banner.
# Always "false" in production.
VITE_USE_STATIC_FALLBACK=false
